<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Book of the End"
           Manufacturer="Book of the End"
           Version="2.8.2.0"
           UpgradeCode="7F3A2C1E-9B44-4E2A-8D1C-2A6F5B0E4C77"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="Book of the End - Offline Windows Data Recovery"
                        Manufacturer="Book of the End" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit." />

    <!--
      Block direct .msi installs. The bundle (Setup.exe) passes INSTALLEDFROMBUNDLE=1.
      "Installed" keeps uninstall/repair/modify working for an already-installed product.
    -->
    <Property Id="INSTALLEDFROMBUNDLE" Secure="yes" />
    <Launch Condition="INSTALLEDFROMBUNDLE OR Installed"
            Message="Please run the Book of the End Setup.exe to install. This .msi cannot be installed on its own." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Shell / Start menu icon: extract from the published exe so it matches the running app. -->
    <Icon Id="ProductIcon.exe" SourceFile="$(var.PublishDir)BookOfTheEnd.exe" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon.exe" />

    <!-- Launch app after install/update.
         Directory-type CA: ExeCommand is a formatted string so [INSTALLFOLDER] resolves at runtime. -->
    <CustomAction Id="LaunchApp"
                  Directory="INSTALLFOLDER"
                  ExeCommand="&quot;[INSTALLFOLDER]BookOfTheEnd.exe&quot;"
                  Execute="immediate"
                  Return="asyncNoWait"
                  Impersonate="yes" />

    <!--
      BookOfTheEnd opens raw volume handles (\\.\C: via CreateFileW) for disk recovery.
      Windows Defender's heuristic engine treats this as ransomware-like behavior and
      quarantines BookOfTheEnd.exe as soon as it lands on disk, breaking the install.

      Fix: add the install folder to Defender's exclusion list BEFORE InstallFiles copies
      any files. The exclusion is removed cleanly on uninstall.
      Return="ignore" means a non-zero PowerShell exit code does not roll back the install
      (e.g. if Defender is disabled, Add-MpPreference returns an error).
    -->
    <CustomAction Id="AddDefenderExclusion"
                  Directory="INSTALLFOLDER"
                  ExeCommand="[System64Folder]WindowsPowerShell\v1.0\powershell.exe -NonInteractive -WindowStyle Hidden -Command &quot;Add-MpPreference -ExclusionPath '[INSTALLFOLDER]' -ErrorAction SilentlyContinue&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="RemoveDefenderExclusion"
                  Directory="INSTALLFOLDER"
                  ExeCommand="[System64Folder]WindowsPowerShell\v1.0\powershell.exe -NonInteractive -WindowStyle Hidden -Command &quot;Remove-MpPreference -ExclusionPath '[INSTALLFOLDER]' -ErrorAction SilentlyContinue&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Installer UI: license + choose install dir -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <ui:WixUI Id="WixUI_InstallDir" />


    <!-- WebView2 Runtime detection (PDF preview). Installed silently if missing. -->
    <Property Id="WEBVIEW2WOW64" Secure="yes">
      <RegistrySearch Id="WebView2Wow64Search"
                      Root="HKLM"
                      Key="SOFTWARE\WOW6432Node\Microsoft\EdgeUpdate\Clients\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}"
                      Name="pv"
                      Type="raw" />
    </Property>
    <Property Id="WEBVIEW2NATIVE" Secure="yes">
      <RegistrySearch Id="WebView2NativeSearch"
                      Root="HKLM"
                      Key="SOFTWARE\Microsoft\EdgeUpdate\Clients\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}"
                      Name="pv"
                      Type="raw" />
    </Property>

    <Binary Id="WebView2Bootstrapper" SourceFile="redist\MicrosoftEdgeWebview2Setup.exe" />

    <CustomAction Id="InstallWebView2"
                  BinaryRef="WebView2Bootstrapper"
                  ExeCommand="/silent /install"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Exclusion must be set before files land on disk so Defender never sees the raw exe. -->
      <Custom Action="AddDefenderExclusion" Before="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="InstallWebView2" Before="InstallFiles" Condition="NOT WEBVIEW2WOW64 AND NOT WEBVIEW2NATIVE" />
      <!-- Auto-relaunch when upgrading from a previous version (bundle runs MSI silently, so no ExitDialog) -->
      <Custom Action="LaunchApp" After="InstallFinalize"
              Condition="WIX_UPGRADE_DETECTED AND NOT REMOVE" />
      <!-- Remove the exclusion when the user uninstalls so we leave no trace in Defender settings. -->
      <Custom Action="RemoveDefenderExclusion" Before="RemoveFiles" Condition="REMOVE" />
    </InstallExecuteSequence>

    <!-- Install layout -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Book of the End" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="Book of the End" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainApplication" Title="Book of the End" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcuts" />
    </Feature>

    <!-- All published files harvested from the self-contained publish output -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(PublishDir)\**" />
    </ComponentGroup>

    <!-- Start Menu + Desktop shortcuts -->
    <Component Id="ApplicationShortcuts" Directory="AppShortcutFolder" Guid="1C9D4B2A-3E55-4A1B-9C2D-6E7F8A0B1C2D">
      <Shortcut Id="StartMenuShortcut"
                Name="Book of the End"
                Description="Offline Windows data recovery"
                Target="[INSTALLFOLDER]BookOfTheEnd.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="ProductIcon.exe"
                IconIndex="0" />
      <Shortcut Id="DesktopShortcut"
                Directory="DesktopFolder"
                Name="Book of the End"
                Description="Offline Windows data recovery"
                Target="[INSTALLFOLDER]BookOfTheEnd.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="ProductIcon.exe"
                IconIndex="0" />
      <RemoveFolder Id="RemoveAppShortcutFolder" Directory="AppShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\Book of the End"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

  </Package>
</Wix>
