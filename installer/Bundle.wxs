<?xml version="1.0" encoding="UTF-8"?>
<!--
  Recommended distribution package: a single setup.exe that installs WebView2 (if missing)
  and then the Book of the End MSI. Built by build/build-installer.ps1.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="Book of the End"
          Manufacturer="Book of the End"
          Version="2.8.1.0"
          UpgradeCode="8E4B3D2C-1A09-4F5E-9C6D-3B7A8E0F1D22"
          IconSourceFile="..\src\BookOfTheEnd\app.ico">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
          LogoFile="assets\logo-64.png"
          LicenseUrl=""
          Theme="hyperlinkLicense"
          ShowVersion="yes"
          LaunchTarget="[ProgramFiles64Folder]Book of the End\BookOfTheEnd.exe" />
    </BootstrapperApplication>

    <!-- Detect Evergreen WebView2 Runtime (required for PDF preview). -->
    <util:RegistrySearch Id="WebView2Wow64"
                         Root="HKLM"
                         Key="SOFTWARE\WOW6432Node\Microsoft\EdgeUpdate\Clients\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}"
                         Value="pv"
                         Variable="WebView2VersionWow64"
                         Result="exists" />
    <util:RegistrySearch Id="WebView2Native"
                         Root="HKLM"
                         Key="SOFTWARE\Microsoft\EdgeUpdate\Clients\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}"
                         Value="pv"
                         Variable="WebView2VersionNative"
                         Result="exists" />

    <Chain>
      <!-- Install the app first so the setup window stays in front during the main work. -->
      <MsiPackage Id="BookOfTheEndMsi"
                  SourceFile="$(var.MsiPath)"
                  DisplayName="Book of the End"
                  Compressed="yes"
                  Vital="yes">
        <!-- Marker so the MSI can refuse to install unless launched from this bundle. -->
        <MsiProperty Name="INSTALLEDFROMBUNDLE" Value="1" />
      </MsiPackage>

      <!-- WebView2 runs after the app; use /install (not /silent) so its UI stays visible if needed. -->
      <ExePackage Id="WebView2Runtime"
                  DisplayName="Microsoft Edge WebView2 Runtime"
                  SourceFile="redist\MicrosoftEdgeWebview2Setup.exe"
                  Permanent="yes"
                  Vital="no"
                  DetectCondition="WebView2VersionWow64 OR WebView2VersionNative"
                  InstallArguments="/install"
                  RepairArguments="/repair"
                  UninstallArguments="/uninstall /silent">
        <ExitCode Value="0" Behavior="success" />
        <ExitCode Value="3010" Behavior="success" />
      </ExePackage>
    </Chain>

  </Bundle>
</Wix>
