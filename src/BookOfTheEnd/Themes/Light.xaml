<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Mode: white + purple -->
    <Color x:Key="AccentColor">#7C3AED</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FAF9FE" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#F2EEFB" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E7E1F5" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E1B2E" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6E6880" />

    <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#6D28D9" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#5B21B6" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="#EEE8FC" />

    <SolidColorBrush x:Key="HeaderBrush" Color="#F2EEFB" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#E7DBFA" />

    <SolidColorBrush x:Key="SuccessBrush" Color="#2E9E4F" />
    <SolidColorBrush x:Key="WarningBrush" Color="#C9821A" />
    <SolidColorBrush x:Key="DangerBrush" Color="#C62828" />

    <!-- Title bar / chrome -->
    <SolidColorBrush x:Key="TitleBarBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="WindowBtnHoverBrush" Color="#ECE7F8" />
    <SolidColorBrush x:Key="CloseBtnHoverBrush" Color="#C42B1C" />

    <!-- Chips / tags -->
    <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#EEE8FC" />
    <SolidColorBrush x:Key="ChipTextBrush" Color="#6D28D9" />

    <!-- Status dots -->
    <SolidColorBrush x:Key="StatusOnlineBrush" Color="#2E9E4F" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#C9821A" />
    <SolidColorBrush x:Key="StatusOfflineBrush" Color="#B9B4C7" />

    <!-- Selectable card -->
    <SolidColorBrush x:Key="CardSelectedBorderBrush" Color="#7C3AED" />
    <SolidColorBrush x:Key="CardSelectedFillBrush" Color="#F5F0FE" />

    <LinearGradientBrush x:Key="HeaderBarBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7C3AED" Offset="0" />
        <GradientStop Color="#9F67F0" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="HeaderBarTextBrush" Color="#FFFFFF" />

</ResourceDictionary>
