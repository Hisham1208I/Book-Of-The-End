<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Mode: black + gold -->
    <Color x:Key="AccentColor">#D4AF37</Color>

    <SolidColorBrush x:Key="BackgroundBrush" Color="#0E0E11" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#17171B" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1E1E23" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2A2A30" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F1E8" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E8A7E" />

    <SolidColorBrush x:Key="AccentBrush" Color="#D4AF37" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#E2C254" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#B8962C" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#14140F" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="#2A2412" />

    <SolidColorBrush x:Key="HeaderBrush" Color="#1A1A1E" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#2A2412" />

    <SolidColorBrush x:Key="SuccessBrush" Color="#3FB950" />
    <SolidColorBrush x:Key="WarningBrush" Color="#E0A33E" />
    <SolidColorBrush x:Key="DangerBrush" Color="#EF5350" />

    <!-- Title bar / chrome -->
    <SolidColorBrush x:Key="TitleBarBrush" Color="#0B0B0E" />
    <SolidColorBrush x:Key="WindowBtnHoverBrush" Color="#26262B" />
    <SolidColorBrush x:Key="CloseBtnHoverBrush" Color="#C42B1C" />

    <!-- Chips / tags -->
    <SolidColorBrush x:Key="ChipBackgroundBrush" Color="#241F12" />
    <SolidColorBrush x:Key="ChipTextBrush" Color="#E2C254" />

    <!-- Status dots -->
    <SolidColorBrush x:Key="StatusOnlineBrush" Color="#3FB950" />
    <SolidColorBrush x:Key="StatusWarnBrush" Color="#E0A33E" />
    <SolidColorBrush x:Key="StatusOfflineBrush" Color="#6B6B6B" />

    <!-- Selectable card -->
    <SolidColorBrush x:Key="CardSelectedBorderBrush" Color="#D4AF37" />
    <SolidColorBrush x:Key="CardSelectedFillBrush" Color="#1C1810" />

    <LinearGradientBrush x:Key="HeaderBarBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A1A1E" Offset="0" />
        <GradientStop Color="#2A2412" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="HeaderBarTextBrush" Color="#F4F1E8" />

</ResourceDictionary>
