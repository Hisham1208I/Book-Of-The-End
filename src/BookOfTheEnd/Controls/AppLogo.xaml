<UserControl x:Class="BookOfTheEnd.Controls.AppLogo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Width="{Binding LogoSize, ElementName=Root}"
             Height="{Binding LogoSize, ElementName=Root}">
    <!-- Minimal open-book mark: two clean planes meeting at a spine. Scales with theme accent. -->
    <Viewbox Stretch="Uniform">
        <Canvas Width="24" Height="24">
            <Path Data="M4,5 L12,8.5 L12,19 L4,15.5 Z"
                  Fill="{DynamicResource AccentBrush}" Opacity="0.82" />
            <Path Data="M20,5 L12,8.5 L12,19 L20,15.5 Z"
                  Fill="{DynamicResource AccentBrush}" />
            <Rectangle Canvas.Left="11.25" Canvas.Top="8" Width="1.5" Height="11"
                       RadiusX="0.75" RadiusY="0.75"
                       Fill="{DynamicResource AccentBrush}" Opacity="0.45" />
        </Canvas>
    </Viewbox>
</UserControl>
