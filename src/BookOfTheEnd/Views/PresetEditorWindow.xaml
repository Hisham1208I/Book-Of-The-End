<Window x:Class="BookOfTheEnd.Views.PresetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Scan Preset"
        Width="460" Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="New Scan Preset" Style="{StaticResource H1}" />
            <TextBlock Text="Save a reusable scan configuration." Style="{StaticResource Caption}" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Name" Style="{StaticResource Caption}" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" Text="My preset" />

            <TextBlock Text="Description" Style="{StaticResource Caption}" Margin="0,12,0,4" />
            <TextBox x:Name="DescBox" Text="" />

            <TextBlock Text="Scan mode" Style="{StaticResource Caption}" Margin="0,14,0,4" />
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="QuickRadio" Content="Quick Scan" IsChecked="True"
                             GroupName="mode" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,18,0" />
                <RadioButton x:Name="DeepRadio" Content="Deep Scan"
                             GroupName="mode" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <TextBlock Text="File types (first selected becomes the tag)" Style="{StaticResource Caption}" Margin="0,14,0,4" />
            <StackPanel>
                <CheckBox x:Name="CbImages" Content="Images" IsChecked="True" />
                <CheckBox x:Name="CbVideos" Content="Videos" />
                <CheckBox x:Name="CbAudio" Content="Audio" />
                <CheckBox x:Name="CbDocuments" Content="Documents" />
                <CheckBox x:Name="CbArchives" Content="Archives" />
                <CheckBox x:Name="CbOther" Content="Other" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="100" Click="OnCancel" />
            <Button Content="Save Preset" Style="{StaticResource AccentButton}" Width="130" Margin="8,0,0,0" Click="OnSave" />
        </StackPanel>
    </Grid>
</Window>
