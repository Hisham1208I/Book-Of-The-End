<Window x:Class="BookOfTheEnd.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Book of the End"
        Width="460"
        SizeToContent="Height"
        MinHeight="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border x:Name="IconBadge" Width="40" Height="40" CornerRadius="10"
                    Background="{DynamicResource AccentMutedBrush}" Margin="0,0,12,0">
                <TextBlock x:Name="IconGlyph" FontFamily="{StaticResource IconFont}" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource AccentBrush}" Text="&#xE946;" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Style="{StaticResource H1}" TextWrapping="Wrap" />
                <TextBlock x:Name="SubtitleText" Style="{StaticResource Caption}" Margin="0,2,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <TextBlock x:Name="MessageText" Grid.Row="1" Style="{StaticResource Body}"
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <Border x:Name="DetailsCard" Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="DetailsText" Style="{StaticResource Caption}" TextWrapping="Wrap"
                       FontFamily="Consolas, Segoe UI" />
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" Width="100" Click="OnCancel" />
            <Button x:Name="OkButton" Content="OK" Style="{StaticResource AccentButton}" Width="110"
                    Margin="8,0,0,0" Click="OnOk" IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>
