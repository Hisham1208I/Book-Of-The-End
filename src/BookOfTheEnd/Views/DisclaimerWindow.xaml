<Window x:Class="BookOfTheEnd.Views.DisclaimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Disclaimer - Book of the End"
        Width="560" Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Book of the End" Style="{StaticResource H1}" />
            <TextBlock Text="Data Recovery — Important Information" Style="{StaticResource Caption}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Recovery success depends heavily on the physical condition of the drive and whether the deleted data has already been overwritten by new writes." />
                    <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Not all deleted or formatted files can be recovered. Files whose clusters have been reused are unrecoverable, and partially overwritten files may be corrupt." />
                    <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Original file names, folder paths, and timestamps may not always be available — especially for files reconstructed by signature carving during a Deep Scan. In those cases a safe replacement name is generated and the item is clearly marked." />
                    <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="To maximize your chances: stop using the affected drive immediately, and always recover files to a DIFFERENT drive than the one being scanned." />
                    <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap"
                               Text="Book of the End runs fully offline. It only reads from the selected drive and never transmits data anywhere. Raw disk access requires administrator privileges." />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2" Content="I understand" Style="{StaticResource AccentButton}"
                HorizontalAlignment="Right" Margin="0,14,0,0" Width="130" Click="OnClose" />
    </Grid>
</Window>
